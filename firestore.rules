rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function householdMemberPath(householdId, userId) {
      return /databases/$(database)/documents/households/$(householdId)/members/$(userId);
    }

    function householdInvitationPath(householdId, invitationId) {
      return /databases/$(database)/documents/households/$(householdId)/invitations/$(invitationId);
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && exists(householdMemberPath(householdId, request.auth.uid))
        && get(householdMemberPath(householdId, request.auth.uid)).data.status == "active";
    }

    function isHouseholdAdmin(householdId) {
      return isHouseholdMember(householdId)
        && (
          get(householdMemberPath(householdId, request.auth.uid)).data.role == "owner"
          || get(householdMemberPath(householdId, request.auth.uid)).data.role == "admin"
        );
    }

    function isHouseholdOwner(householdId) {
      return isHouseholdMember(householdId)
        && get(householdMemberPath(householdId, request.auth.uid)).data.role == "owner";
    }

    function isCreatingOwnHousehold() {
      return signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string;
    }

    function isCreatingOwnOwnerMembership(householdId, userId) {
      return isSelf(userId)
        && exists(/databases/$(database)/documents/households/$(householdId))
        && get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid
        && request.resource.data.role == "owner"
        && request.resource.data.status == "active";
    }

    function isCreatingOwnOwnerMembershipLink(userId, householdId) {
      return isSelf(userId)
        && exists(/databases/$(database)/documents/households/$(householdId))
        && get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid
        && request.resource.data.householdId == householdId
        && request.resource.data.role == "owner"
        && request.resource.data.status == "active";
    }

    function authEmailMatches(normalizedEmail) {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.lower() == normalizedEmail;
    }

    function invitationIsNotExpired(invitation) {
      return !("expiresAt" in invitation)
        || invitation.expiresAt == ""
        || (
          "expiresAtMillis" in invitation
          && invitation.expiresAtMillis is number
          && invitation.expiresAtMillis > request.time.toMillis()
        );
    }

    function isOwnPendingInvitation(householdId, invitationId) {
      return signedIn()
        && exists(householdInvitationPath(householdId, invitationId))
        && get(householdInvitationPath(householdId, invitationId)).data.status == "pending"
        && authEmailMatches(get(householdInvitationPath(householdId, invitationId)).data.normalizedEmail)
        && invitationIsNotExpired(get(householdInvitationPath(householdId, invitationId)).data);
    }

    function isAcceptingOwnInvitation(householdId, invitationId) {
      return isOwnPendingInvitation(householdId, invitationId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "acceptedBy",
          "acceptedAt"
        ])
        && request.resource.data.status == "accepted"
        && request.resource.data.acceptedBy == request.auth.uid
        && request.resource.data.acceptedAt is string;
    }

    function isRevokingPendingInvitation(householdId, invitationId) {
      return isHouseholdAdmin(householdId)
        && resource.data.status == "pending"
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "revokedBy",
          "revokedAt"
        ])
        && request.resource.data.status == "revoked"
        && request.resource.data.revokedBy == request.auth.uid
        && request.resource.data.revokedAt is string;
    }

    function isRenamingHousehold(householdId) {
      return isHouseholdOwner(householdId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "updatedAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.updatedAt is string;
    }

    function canRemoveHouseholdMember(householdId, userId) {
      return isHouseholdAdmin(householdId)
        && userId != request.auth.uid
        && exists(householdMemberPath(householdId, userId))
        && get(householdMemberPath(householdId, userId)).data.status == "active"
        && get(householdMemberPath(householdId, userId)).data.role != "owner"
        && (
          get(householdMemberPath(householdId, userId)).data.role != "admin"
          || isHouseholdOwner(householdId)
        );
    }

    function isRemovingHouseholdMember(householdId, userId) {
      return canRemoveHouseholdMember(householdId, userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "removedBy",
          "removedAt",
          "updatedAt"
        ])
        && request.resource.data.status == "removed"
        && request.resource.data.removedBy == request.auth.uid
        && request.resource.data.removedAt is string
        && request.resource.data.updatedAt is string;
    }

    function isRemovingHouseholdMembershipLink(userId, householdId) {
      return canRemoveHouseholdMember(householdId, userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "removedBy",
          "removedAt",
          "updatedAt"
        ])
        && request.resource.data.status == "removed"
        && request.resource.data.removedBy == request.auth.uid
        && request.resource.data.removedAt is string
        && request.resource.data.updatedAt is string;
    }

    function invitationRole(householdId, invitationId) {
      return get(householdInvitationPath(householdId, invitationId)).data.role;
    }

    function isCreatingOwnInvitedMember(householdId, userId) {
      return isSelf(userId)
        && request.resource.data.invitationId is string
        && isOwnPendingInvitation(householdId, request.resource.data.invitationId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == invitationRole(householdId, request.resource.data.invitationId)
        && request.resource.data.status == "active";
    }

    function isCreatingOwnInvitedMembership(userId, householdId) {
      return isSelf(userId)
        && request.resource.data.invitationId is string
        && isOwnPendingInvitation(householdId, request.resource.data.invitationId)
        && request.resource.data.householdId == householdId
        && request.resource.data.role == invitationRole(householdId, request.resource.data.invitationId)
        && request.resource.data.status == "active";
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);

      match /householdMemberships/{householdId} {
        allow read, delete: if isSelf(userId);
        allow update: if isSelf(userId)
          || isRemovingHouseholdMembershipLink(userId, householdId);
        allow create: if isCreatingOwnOwnerMembershipLink(userId, householdId)
          || isHouseholdMember(householdId)
          || isCreatingOwnInvitedMembership(userId, householdId);
      }
    }

    match /households/{householdId} {
      allow create: if isCreatingOwnHousehold();
      allow read, delete: if isHouseholdMember(householdId);
      allow update: if isRenamingHousehold(householdId);

      match /members/{userId} {
        allow create: if isCreatingOwnOwnerMembership(householdId, userId)
          || isHouseholdMember(householdId)
          || isCreatingOwnInvitedMember(householdId, userId);
        allow read, delete: if isHouseholdMember(householdId);
        allow update: if isRemovingHouseholdMember(householdId, userId)
          || (isHouseholdMember(householdId) && userId == request.auth.uid);
      }

      match /items/{itemId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /locations/{locationId} {
        allow read, write: if isHouseholdMember(householdId);
      }

      match /invitations/{invitationId} {
        allow get: if isHouseholdMember(householdId)
          || isOwnPendingInvitation(householdId, invitationId);
        allow list, create, delete: if isHouseholdMember(householdId);
        allow update: if isRevokingPendingInvitation(householdId, invitationId)
          || isAcceptingOwnInvitation(householdId, invitationId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
